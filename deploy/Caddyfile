# BaoTheX reverse proxy. Set DOMAIN in the production environment.
{$DOMAIN} {
	encode zstd gzip

	# API is served under /api/* (and the Telegram webhook).
	handle /api/* {
		reverse_proxy api:8080
	}
	handle /media/* {
		reverse_proxy api:8080
	}
	handle /healthz {
		reverse_proxy api:8080
	}

	handle {
		reverse_proxy web:3000
	}
}
