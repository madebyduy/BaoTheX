# Binaries
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
apps/api/api
apps/worker/worker

# Env
# Catch every .env variant (.env.backup, .env.prod, .env.old) — only the
# committed .env.example is exempt. Listing just ".env" left a copy like
# .env.backup tracked and a real API key one `git add .` away from the remote.
.env
.env.*
!.env.example
var/
*.local

# Go
vendor/
/tmp/
coverage.out
*.test
*.out

# Editor
.idea/
.vscode/
*.swp
.DS_Store

# Node (web app, added later)
apps/web/node_modules/
apps/web/.next/
apps/web/out/

# Postgres data (if bind-mounted locally)
deploy/pgdata/
