# ============ CORE ============
# PostgreSQL connection string (used by both api and worker)
DATABASE_URL=postgres://repwire:repwire@localhost:5432/repwire?sslmode=disable

# Secret used to derive/verify session-related HMACs. 32+ random bytes, base64 or hex.
SESSION_SECRET=change-me-to-a-long-random-string

# Public base URL of the site, used in Telegram deep links, emails, sitemaps.
PUBLIC_BASE_URL=http://localhost:3000
DOMAIN=baothex.vn

# ============ API SERVER ============
API_ADDR=:8080
# Comma separated list of allowed CORS origins for the browser/web app.
CORS_ORIGINS=http://localhost:3000
# Only these reverse proxies may supply X-Forwarded-For for security/rate-limit
# decisions. Production Docker/Caddy normally reaches the API from a private
# bridge subnet; narrow this to that subnet when it is known.
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# ============ WORKER ============
# Number of concurrent job-processing goroutines.
WORKER_CONCURRENCY=8

# ============ YOUTUBE ============
YOUTUBE_API_KEY=

# Optional fallback sources can use public YouTube channel RSS without this key.

# ============ TELEGRAM ============
TELEGRAM_BOT_TOKEN=
# Secret token verified on the incoming webhook (X-Telegram-Bot-Api-Secret-Token header).
TELEGRAM_WEBHOOK_SECRET=
# Bot username without @, used to build https://t.me/<bot>?start=<code> deep links.
TELEGRAM_BOT_USERNAME=RepWireBot
TELEGRAM_POLLING=false

# ============ AUDIO BRIEFS ============
# The audio brief is narrated by a fallback chain, tried in order: Edge, then
# Google Translate, then Gemini. The first that answers wins. The point is to
# stay off Gemini's limited free quota, which capped TTS at a few hundred calls
# a day and kept killing the morning edition.
#
# Edge (Microsoft's free read-aloud): best voice, no key, no quota — but its
# synthesis endpoint is IP-blocked from many datacenter ranges (a 403 on
# connect), so it tends to work from home and fail from a server. Empty disables.
TTS_EDGE_VOICE=vi-VN-NamMinhNeural
# Route Edge through an HTTP(S) or SOCKS5 proxy to escape that IP block —
# e.g. socks5://user:pass@host:1080 or http://host:8080. It must be a RESIDENTIAL
# proxy; commercial/datacenter proxies (and most VPN exit IPs) are blocked too.
# A system-wide VPN needs nothing here — the OS routes Edge through it already.
TTS_EDGE_PROXY=
# Google Translate's free voice: works from anywhere but sounds flat and robotic,
# so it is OFF by default. It stays in the code as an emergency last resort — set
# TTS_GOOGLE_LANG=vi to enable it for days when both Edge and Gemini are down and
# a plain voice beats no brief at all. Left empty, the chain is Edge → Gemini.
TTS_GOOGLE_LANG=
# Gemini: the paid-quota last resort, used only when both free voices fail. Its
# dedicated key pool (comma-separated) stays separate from LLM_API_KEY so
# summarization can't drain the audio quota; empty falls back to the LLM keys.
TTS_API_KEY=
TTS_MODEL=gemini-2.5-flash-preview-tts
TTS_VOICE=Erinome
MEDIA_STORAGE_DIR=./var/media
MEDIA_PUBLIC_BASE_URL=http://localhost:8080
# FFMPEG_PATH and VIDEO_FONT_FILE used to live here, for a "generate_video_brief"
# job that renders an MP4 recap. There is no such job: no constant, no handler,
# no ffmpeg call anywhere in the Go tree. It was removed and its configuration
# was not, so both files went on asking operators to install ffmpeg and name a
# font for a feature that could not run. Deleted rather than commented back in —
# if the video brief returns, its config should return with it.

# ============ WEB PUSH / PWA ============
# Generate a VAPID key pair before enabling server-side Web Push.
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@example.com

# One-time/idempotent administrator seed (used by: go run ./tools/seed-admin)
ADMIN_EMAIL=admin@baothex.vn
ADMIN_PASSWORD=change-this-to-a-long-random-password
ADMIN_NAME=Toà soạn BaoTheX

# ============ SEPAY / PREMIUM ============
SEPAY_MERCHANT=
SEPAY_SECRET_KEY=
SEPAY_BASE_URL=https://pay.sepay.vn
SEPAY_IPN_SECRET_KEY=
SEPAY_API_TOKEN=
SEPAY_BANK_ACCOUNT_ID=
BANK_INFO=
BANK_ACCOUNT_NUMBER=
SEPAY_VA_PREFIX=BTX
PREMIUM_MONTHLY_PRICE=39000

# ============ LLM / SUMMARIZATION ============
# Anthropic-compatible or OpenAI-compatible endpoint. Defaults target the Anthropic Messages API.
# One or more API keys, comma-separated. The summarizer rotates to the next key
# when the active one is rate-limited / quota-exhausted (HTTP 429 / RESOURCE_EXHAUSTED).
# Example: LLM_API_KEY=key_one,key_two,key_three
LLM_API_KEY=
LLM_BASE_URL=https://api.anthropic.com/v1/messages
LLM_MODEL=claude-haiku-4-5-20251001
# What one million tokens costs on the account behind LLM_API_KEY. These MUST
# describe the provider named by LLM_BASE_URL — nothing validates that for you,
# and the budget below is computed entirely from them.
#
# The defaults are Anthropic Haiku-class rates, matching the default LLM_MODEL.
# Point LLM_BASE_URL at another provider and these stop being true: they were
# hardcoded at $1/$5 while a deployment ran on Gemini, which billed the meter
# about ten times the real price and, on a free tier, for money never spent.
#
# On a free tier set BOTH to 0. That is not a way of switching the budget off,
# it is the honest number — the calls cost nothing, the provider's own quota is
# the real limit, and a meter that invents spending stops work for no reason.
LLM_INPUT_USD_PER_MTOK=1
LLM_OUTPUT_USD_PER_MTOK=5
# Soft daily spending cap in USD. When exceeded, summarize jobs are deferred.
# Priced by the two rates above, so it only means anything if they are right.
LLM_DAILY_BUDGET_USD=5
#
# IMPORTANT — the score scale. Both thresholds below are compared against
# process.BaseScore, which for an ARTICLE tops out at 40:
#   source quality 20 + published <24h 10 + well-followed topic 10.
# (Only research papers can score higher.) A threshold above 40 therefore does
# not make the gate stricter — it disables whatever it guards. Setting
# LLM_SCORE_THRESHOLD=80 to "save quota" stops every article being summarized
# while changing nothing else. The worker now refuses to start on such a value
# rather than degrade silently.
#
# Only summarize items whose base_score is at least this. Range 0-40.
LLM_SCORE_THRESHOLD=25
# Only translate foreign articles scoring at least this on arrival. Range 0-40,
# but read the note above: if none of your topics has over 50 followers, the real
# article ceiling is 30, so 30 here means "tier-5 source, published today" and
# nothing else. Check before tuning:
#   SELECT type, max(base_score) FROM content_items GROUP BY type;
# Everything below the floor is parked: still clustered and still counted toward
# a story's heat, but costing nothing. Full-body translation is the most
# expensive call we make, so it is reserved for articles that earn a place in
# the public feed. The daily pick ignores this floor for its winning cluster.
LLM_TRANSLATE_MIN_SCORE=30
# How old a foreign article may be and still be worth translating.
# This is what stops the backlog outliving the news inside it. Sources deliver
# far more per day than a throttled key can translate, so the queue only ever
# grows; without a cutoff the worker ends up translating last week while today
# goes unread. Past this age a story is abandoned on purpose, while that is
# still our choice, rather than dropped by accident when the backlog wins.
LLM_TRANSLATE_MAX_AGE_HOURS=36
# Max LLM calls per hour (rate limiting / cost control). This paces background
# work only; the daily editorial pick bypasses it and answers to the daily
# budget instead, so routine backlog can never starve the day's one piece.
LLM_MAX_CALLS_PER_HOUR=120
# Max LLM calls per MINUTE — the one that stops a stampede.
#
# The hourly cap bounds the total but says nothing about the rate: 60 per hour
# happily permits all 60 in the first minute. With several worker slots each
# retrying across several keys, a burst of twenty-plus requests can hit a
# provider that allows five per minute; everything past the fifth is rejected,
# each rejection burns a retry, and jobs die reporting "all keys failed" while
# both keys are healthy and the budget is untouched.
#
# Shared by the summarizer AND the TTS renderer — one Gemini project, one
# allowance. Free-tier Gemini Flash permits 5/minute, so 4 leaves room for
# retries. Set 0 to disable pacing on a paid tier with headroom.
LLM_MAX_CALLS_PER_MINUTE=4
# Provider requests per day (RPD), reset at midnight Pacific time. Background
# work may use only the non-reserved share; editor-triggered drafts use the
# reserve. Two keys in one Google project still share this same quota.
LLM_MAX_CALLS_PER_DAY=1000
LLM_EDITORIAL_RESERVE_PERCENT=30

# ============ EDITORIAL ============
# Hour (Vietnam time, 0-23) from which the desk may commit to a story, and how
# many it commits to in a day. Picks are spaced at least three hours apart, so
# these two together describe the shape of the day rather than a single moment.
#
# This was DAILY_PICK_HOUR=21 and one story per day, and the reason given was
# that the newsroom had to "commit its LLM budget" to the single best story. The
# budget was a fiction: a pricing bug billed free-tier Gemini calls at Anthropic
# rates, so the meter read $0.91 of a $0.50 ceiling on a real spend of $0.00.
# One article an evening was all that fiction could afford. The bug is fixed and
# the scarcity was never real — on a normal day 18 clusters carry the three
# translated sources an analysis needs while whole hours pass using six calls of
# a 240-call allowance.
#
# The evening's real argument still holds, though, and the gap is what keeps it:
# heat is measured over 24 hours, so a story that was merely loud at 9am fades
# before the next pick and stops winning. Raise the count only as far as someone
# will actually review the drafts — the reviewer is the bottleneck, not quota.
EDITORIAL_START_HOUR=9
EDITORIAL_PICKS_PER_DAY=3

# ============ MISC ============
# text | json  (slog handler)
LOG_FORMAT=json
# debug | info | warn | error
LOG_LEVEL=info
# Optional, documented free sports feeds. Missing tokens never block startup.
SPORTS_DATA_MODE=free
FOOTBALL_DATA_TOKEN=
PANDASCORE_TOKEN=
OPENF1_ENABLED=true
THESPORTSDB_KEY=123

# ============ ERROR MONITORING (optional) ============
# Sentry is wired but off by default; both integrations are no-ops without a DSN.
#
# Next.js (apps/web): install the SDK, then set SENTRY_DSN in the web env.
#   cd apps/web && npm i @sentry/nextjs
# apps/web/instrumentation.ts initialises Sentry only when SENTRY_DSN is present.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
#
# Go (api + worker): add the SDK and initialise it in apps/api/main.go and
# apps/worker/main.go guarded by SENTRY_DSN:
#   go get github.com/getsentry/sentry-go
# (left as a follow-up so the build has no hard dependency on the SDK).
