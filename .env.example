# ============ CORE ============
# PostgreSQL connection string (used by both api and worker)
DATABASE_URL=postgres://repwire:repwire@localhost:5432/repwire?sslmode=disable

# Secret used to derive/verify session-related HMACs. 32+ random bytes, base64 or hex.
SESSION_SECRET=change-me-to-a-long-random-string

# Public base URL of the site, used in Telegram deep links, emails, sitemaps.
PUBLIC_BASE_URL=http://localhost:3000
DOMAIN=baothex.vn

# ============ API SERVER ============
API_ADDR=:8080
# Comma separated list of allowed CORS origins for the browser/web app.
CORS_ORIGINS=http://localhost:3000

# ============ WORKER ============
# Number of concurrent job-processing goroutines.
WORKER_CONCURRENCY=8

# ============ YOUTUBE ============
YOUTUBE_API_KEY=

# Optional fallback sources can use public YouTube channel RSS without this key.

# ============ TELEGRAM ============
TELEGRAM_BOT_TOKEN=
# Secret token verified on the incoming webhook (X-Telegram-Bot-Api-Secret-Token header).
TELEGRAM_WEBHOOK_SECRET=
# Bot username without @, used to build https://t.me/<bot>?start=<code> deep links.
TELEGRAM_BOT_USERNAME=RepWireBot
TELEGRAM_POLLING=false

# ============ AUDIO / VIDEO BRIEFS ============
# Dedicated key pool for the audio brief (comma-separated), kept separate from
# LLM_API_KEY so summarization can't drain the audio quota. Rotates to the next
# key on quota exhaustion. When empty, falls back to sharing the LLM keys.
TTS_API_KEY=
TTS_MODEL=gemini-2.5-flash-preview-tts
TTS_VOICE=Erinome
MEDIA_STORAGE_DIR=./var/media
MEDIA_PUBLIC_BASE_URL=http://localhost:8080
FFMPEG_PATH=ffmpeg
VIDEO_FONT_FILE=C:/Windows/Fonts/arialbd.ttf

# ============ WEB PUSH / PWA ============
# Generate a VAPID key pair before enabling server-side Web Push.
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@example.com

# One-time/idempotent administrator seed (used by: go run ./tools/seed-admin)
ADMIN_EMAIL=admin@baothex.vn
ADMIN_PASSWORD=change-this-to-a-long-random-password
ADMIN_NAME=Toà soạn BaoTheX

# ============ SEPAY / PREMIUM ============
SEPAY_MERCHANT=
SEPAY_SECRET_KEY=
SEPAY_BASE_URL=https://pay.sepay.vn
SEPAY_IPN_SECRET_KEY=
SEPAY_API_TOKEN=
SEPAY_BANK_ACCOUNT_ID=
BANK_INFO=
BANK_ACCOUNT_NUMBER=
SEPAY_VA_PREFIX=BTX
PREMIUM_MONTHLY_PRICE=39000

# ============ LLM / SUMMARIZATION ============
# Anthropic-compatible or OpenAI-compatible endpoint. Defaults target the Anthropic Messages API.
# One or more API keys, comma-separated. The summarizer rotates to the next key
# when the active one is rate-limited / quota-exhausted (HTTP 429 / RESOURCE_EXHAUSTED).
# Example: LLM_API_KEY=key_one,key_two,key_three
LLM_API_KEY=
LLM_BASE_URL=https://api.anthropic.com/v1/messages
LLM_MODEL=claude-haiku-4-5-20251001
# Soft daily spending cap in USD. When exceeded, summarize jobs are deferred.
LLM_DAILY_BUDGET_USD=5
#
# IMPORTANT — the score scale. Both thresholds below are compared against
# process.BaseScore, which for an ARTICLE tops out at 40:
#   source quality 20 + published <24h 10 + well-followed topic 10.
# (Only research papers can score higher.) A threshold above 40 therefore does
# not make the gate stricter — it disables whatever it guards. Setting
# LLM_SCORE_THRESHOLD=80 to "save quota" stops every article being summarized
# while changing nothing else. The worker now refuses to start on such a value
# rather than degrade silently.
#
# Only summarize items whose base_score is at least this. Range 0-40.
LLM_SCORE_THRESHOLD=25
# Only translate foreign articles scoring at least this on arrival. Range 0-40,
# but read the note above: if none of your topics has over 50 followers, the real
# article ceiling is 30, so 30 here means "tier-5 source, published today" and
# nothing else. Check before tuning:
#   SELECT type, max(base_score) FROM content_items GROUP BY type;
# Everything below the floor is parked: still clustered and still counted toward
# a story's heat, but costing nothing. Full-body translation is the most
# expensive call we make, so it is reserved for articles that earn a place in
# the public feed. The daily pick ignores this floor for its winning cluster.
LLM_TRANSLATE_MIN_SCORE=30
# How old a foreign article may be and still be worth translating.
# This is what stops the backlog outliving the news inside it. Sources deliver
# far more per day than a throttled key can translate, so the queue only ever
# grows; without a cutoff the worker ends up translating last week while today
# goes unread. Past this age a story is abandoned on purpose, while that is
# still our choice, rather than dropped by accident when the backlog wins.
LLM_TRANSLATE_MAX_AGE_HOURS=36
# Max LLM calls per hour (rate limiting / cost control). This paces background
# work only; the daily editorial pick bypasses it and answers to the daily
# budget instead, so routine backlog can never starve the day's one piece.
LLM_MAX_CALLS_PER_HOUR=120
# Max LLM calls per MINUTE — the one that stops a stampede.
#
# The hourly cap bounds the total but says nothing about the rate: 60 per hour
# happily permits all 60 in the first minute. With several worker slots each
# retrying across several keys, a burst of twenty-plus requests can hit a
# provider that allows five per minute; everything past the fifth is rejected,
# each rejection burns a retry, and jobs die reporting "all keys failed" while
# both keys are healthy and the budget is untouched.
#
# Shared by the summarizer AND the TTS renderer — one Gemini project, one
# allowance. Free-tier Gemini Flash permits 5/minute, so 4 leaves room for
# retries. Set 0 to disable pacing on a paid tier with headroom.
LLM_MAX_CALLS_PER_MINUTE=4

# ============ EDITORIAL ============
# Hour (Vietnam time, 0-23) at which the newsroom picks the single hottest story
# of the day and commits the LLM budget to it. Late is deliberate: by evening a
# story has had a full day to be corroborated and argued about, which is what
# separates a real controversy from a headline that merely looked loud at 9am.
DAILY_PICK_HOUR=21

# ============ MISC ============
# text | json  (slog handler)
LOG_FORMAT=json
# debug | info | warn | error
LOG_LEVEL=info
